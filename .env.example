# Brujula Futura - Variables de entorno
# Copia este archivo como .env y completa los valores

# ── General ──────────────────────────────────────
APP_NAME=BrujulaFutura
APP_ENV=development

# ── API Backend (si se implementa en el futuro) ──
VITE_API_URL=http://localhost:3000

# ── Despliegue ────────────────────────────────────
# URL publica del frontend en produccion
VITE_APP_URL=https://brujula-futura.vercel.app

# ── Servicios externos (opcionales) ──────────────
# Google Maps (para mostrar ubicacion de universidades)
VITE_MAPS_API_KEY=

# Firebase (para guardar rutas de usuarios en el futuro)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
